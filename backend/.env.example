# Base de datos
DATABASE_URL="mysql://barberflow:barberflow_pass@localhost:3306/barberflow"

# JWT
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="8h"

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# SMTP (ej. Mailtrap para pruebas, o SMTP real en producción)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BarberFlow <no-reply@barberflow.com>"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10
